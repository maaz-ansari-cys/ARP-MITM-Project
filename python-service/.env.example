# Python Network Service Configuration
# ======================================
# Network settings are AUTO-DETECTED at runtime by default.
# Only override below if auto-detection fails.

MONGODB_URL=mongodb://localhost:
MONGODB_DB_NAME=network_visibility

# Network Configuration
# "auto" = auto-detect interface and subnet at runtime (recommended)
NETWORK_INTERFACE=auto
NETWORK_RANGE=auto

HOST=0.0.0.0
PORT=
CORS_ORIGINS=http://localhost:3000
